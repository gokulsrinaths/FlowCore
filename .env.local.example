# App URL for invite links in emails (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (https://resend.com) — server-only; never expose in client bundles
# RESEND_API_KEY=re_...
#
# Sending to addresses other than your Resend login email requires a verified domain:
# 1. https://resend.com/domains — add your domain, add DNS records, wait until "Verified"
# 2. Set the from address to any sender on that domain (create in Resend or use noreply@):
# RESEND_FROM_EMAIL=FlowCore <noreply@yourdomain.com>
# 3. Copy the same RESEND_FROM_EMAIL into Vercel → Project → Environment Variables (Production)
#
# Until then, the default test sender only allows delivery to your Resend account email.

# Cron: `/api/cron/reminders` (Vercel cron or manual). Must match Vercel project env if using hosted cron.
# CRON_SECRET=generate-a-long-random-string

# Service role: server-only; used by cron to call `flowcore_send_due_reminders`. Never expose to the client.
# SUPABASE_SERVICE_ROLE_KEY=
