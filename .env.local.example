# App URL for invite links in emails (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (https://resend.com) — server-only; never expose in client bundles
# Required for invitation emails (Settings → Team and case invites). Without it, invites are saved but no email is sent.
# RESEND_API_KEY=re_...

# Optional; default uses Resend's test domain — then you can only send TO your Resend account email.
# For other recipients: verify a domain at resend.com/domains and set from to that domain, e.g.:
# RESEND_FROM_EMAIL=FlowCore <noreply@yourdomain.com>

# Cron: `/api/cron/reminders` (Vercel cron or manual). Must match Vercel project env if using hosted cron.
# CRON_SECRET=generate-a-long-random-string

# Service role: server-only; used by cron to call `flowcore_send_due_reminders`. Never expose to the client.
# SUPABASE_SERVICE_ROLE_KEY=
